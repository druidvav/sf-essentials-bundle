{
  "name": "druidvav/essentials-bundle",
  "type": "symfony-bundle",
  "license": "MIT",
  "description": "",
  "autoload": {
    "psr-4": { "": "src/" }
  },
  "require": {
    "php": ">=7.4.0",
    "ext-intl": "*",
    "ext-zlib": "*",
    "ext-iconv": "*",
    "ext-simplexml": "*",
    "ext-json": "*",
    "symfony/contracts": "^1.1|^2.0|^3.0",
    "symfony/dependency-injection": "^5.4",
    "symfony/translation": "^5.4",
    "symfony/framework-bundle": "^5.4",
    "symfony/twig-bundle": "^5.4"
  },
  "suggest": {
    "ext-pcntl": "Required to use some cool doctrine feature with my lib."
  },
  "require-dev": {
    "symfony/process": "^5.4",
    "symfony/console": "^5.4",
    "doctrine/doctrine-bundle": "^2.0",
    "doctrine/orm": "~2.4,>=2.4.5"
  },
  "scripts": {
    "tools:install": "composer --working-dir=tools install",
    "stan": "composer --working-dir=tools phpstan",
    "rector": "composer --working-dir=tools rector:dry-run",
    "rector:fix": "composer --working-dir=tools rector",
    "cs": "composer --working-dir=tools cs",
    "cs:fix": "composer --working-dir=tools cs:fix"
  }
}
