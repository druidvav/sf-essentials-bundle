{
  "name": "druidvav/essentials-bundle-tools",
  "private": true,
  "type": "project",
  "require": {
    "php": "^8.1"
  },
  "require-dev": {
    "rector/rector": "^1.2",
    "phpstan/phpstan": "^1.12",
    "phpstan/phpstan-symfony": "^1.4",
    "symfony/console": "^4.4|^5.0",
    "symfony/contracts": "^1.1|^2.0|^3.0",
    "symfony/dependency-injection": "^4.4|^5.0",
    "symfony/framework-bundle": "^4.4|^5.0",
    "symfony/http-kernel": "^4.4|^5.0",
    "symfony/process": "^4.4|^5.0",
    "symfony/twig-bundle": "^4.4|^5.0",
    "twig/twig": "^2.0|^3.0",
    "doctrine/doctrine-bundle": "^1.4|^2.0",
    "doctrine/orm": "~2.4,>=2.4.5",
    "friendsofphp/php-cs-fixer": "^3.0"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  },
  "scripts": {
    "phpstan": "phpstan analyse -c phpstan.neon --memory-limit=512M",
    "rector": "rector process --config rector.php",
    "rector:dry-run": "rector process --config rector.php --dry-run",
    "cs": "php-cs-fixer fix --diff --dry-run --ansi --show-progress=dots",
    "cs:fix": "php-cs-fixer fix --diff --ansi --show-progress=dots"
  }
}
